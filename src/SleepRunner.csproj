<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net8.0-windows10.0.17763.0</TargetFramework>
    <Platforms>x64</Platforms>
    <AssemblyName>SleepRunner</AssemblyName>
    <Product>SleepRunner</Product>
    <ApplicationIcon>Resources\SleepRunner.ico</ApplicationIcon>
    <RootNamespace>SleepRunner</RootNamespace>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <UseWindowsForms>true</UseWindowsForms>
  </PropertyGroup>

  <ItemGroup>
    <None Remove="Resources\SleepRunner.ico" />
    <None Remove="Resources\SleepRunnerRunning.ico" />
    <EmbeddedResource Include="Resources\SleepRunner.ico" LogicalName="SleepRunner.AppIcon.ico" />
    <EmbeddedResource Include="Resources\SleepRunnerRunning.ico" LogicalName="SleepRunner.RunningAppIcon.ico" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="OpenCvSharp4" Version="4.13.0.20260330" />
    <PackageReference Include="OpenCvSharp4.runtime.win" Version="4.13.0.20260302" />
  </ItemGroup>

  <ItemGroup>
    <None Include="..\assets\events\**\*.json">
      <Link>assets\events\%(RecursiveDir)%(Filename)%(Extension)</Link>
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
    <None Include="..\assets\cards\**\*.json">
      <Link>assets\cards\%(RecursiveDir)%(Filename)%(Extension)</Link>
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
    <None Include="..\assets\trade\**\*.json">
      <Link>assets\trade\%(RecursiveDir)%(Filename)%(Extension)</Link>
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
    <None Include="..\assets\training\**\*.json">
      <Link>assets\training\%(RecursiveDir)%(Filename)%(Extension)</Link>
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
  </ItemGroup>

</Project>
